            if (!prev) return null;
            const newState = { ...prev };
            if (prev.main.base64 === imageToUpscale.base64) {
                newState.main = result;
            } else {
                const variationIndex = prev.variations.findIndex(v => v.base64 === imageToUpscale.base64);
