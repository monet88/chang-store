    const apiError = new Error('Network error');
    mockAxiosInstance.post.mockRejectedValueOnce(apiError);

    // Act & Assert
    await expect(listModels(TEST_ACCESS_TOKEN, 'image')).rejects.toThrow('Network error');
  });
});

