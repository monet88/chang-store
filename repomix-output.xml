    mockAxiosInstance.post.mockResolvedValueOnce({
      data: { data: null },
    });

    // Act
    const result = await listModels(TEST_ACCESS_TOKEN, 'video');

    // Assert
    expect(result).toEqual([]);
  });

  /**
   * Test: Propagates API errors
   */
  it('should throw error when API fails', async () => {
