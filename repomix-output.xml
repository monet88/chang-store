    mockAxiosInstance.post.mockResolvedValueOnce({
      data: { data: { single: 'object' } },
    });

    // Act
    const result = await listModels(TEST_ACCESS_TOKEN, 'image');

    // Assert
    expect(result).toEqual([]);
