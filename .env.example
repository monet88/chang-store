# Chang-Store Environment Variables
# Copy this file to .env.local and fill in your values

# Gemini API Key - Required for AI features
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Client ID - Required for Google Drive sync
# Create one at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application type)
# 2. Add authorized JavaScript origins: http://localhost:3000, your_production_domain
# 3. Copy the Client ID here
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
